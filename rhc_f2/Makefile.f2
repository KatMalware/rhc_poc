CC      = gcc
CFLAGS  = -Wall -Wextra -O2 -std=c11 -D_POSIX_C_SOURCE=200809L
TARGET  = rhc_f2_poc
SRCS    = rhc_f2.c main_f2.c
LIBS    = -lcrypto

all: $(TARGET)

$(TARGET): $(SRCS) rhc_f2.h ../rhc_config.h
	$(CC) $(CFLAGS) -o $(TARGET) $(SRCS) $(LIBS)

clean:
	rm -f $(TARGET) rhc_audit_test.jsonl rhc_audit.jsonl

run: $(TARGET)
	./$(TARGET)

.PHONY: all clean run
